# Template for local profile. Copy to application-local.yaml and update values.
server:
  port: 8020

spring:
  datasource:
    url: jdbc:postgresql://localhost:5432/trustedServicedb
    username: postgres
    password: CHANGE_ME
  jpa:
    hibernate:
      ddl-auto: update

springdoc:
  api-docs:
    path: /api-docs
    groups:
      enabled: true
  swagger-ui:
    path: /swagger-ui

app:
  id: TrustedParty
  fqdn: 127.0.0.1:8020
  trustedCertsDirPath: ${user.dir}/certs/trusted_certs
  publicCertPath: ${user.dir}/certs/cert-dev/cert.pem
  privateKeyPath: ${user.dir}/certs/cert-dev/ec_key.pem
